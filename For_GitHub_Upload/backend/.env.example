# Backend Environment Variables
# Choose AI Provider: groq (recommended, free) or ollama (local, free)
AI_PROVIDER=groq

# For Groq (Free, Instant Setup)
# 1. Go to https://console.groq.com
# 2. Sign up (takes 1 minute, no credit card required)
# 3. Get your API key from the console
# 4. Paste it below
GROQ_API_KEY=gsk_bmB4nxiQnVoZdLsjLjZGWGdgsk_DHz6GrwhzbwQ5tLicXNGWGdyb3FYiYB7inC8kCHWNpiFVo6IswwWyb3FY7Gf3MJSsHXB9JWrlJ9cx18D5

# For Ollama (Local, Completely Free)
# 1. Download Ollama from https://ollama.ai
# 2. Run: ollama pull mistral
# 3. Run: ollama serve (in another terminal)
# 4. Keep default URL below or update if running on different host
# Uncomment the line below to use Ollama instead of Groq
# AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434

# Flask Configuration
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# CORS Settings
CORS_ORIGINS=*
