# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=groq
LLM_BACKEND=groq   # groq | ollama

# ── Groq Key Pool (add up to 25 keys) ────────────────────────────────────────
GROQ_API_KEY_1=your_groq_key_here
# GROQ_API_KEY_2=...
GROQ_BLACKLIST_TTL=60
GROQ_MAX_RETRIES=5

# Primary model
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_ANALYZER=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── Gemini Fallback ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── RapidAPI (Job Search) ─────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Dev:  sqlite:///resumx.db
# Prod: postgresql://user:password@host:5432/resumx
DATABASE_URL=sqlite:///resumx.db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=wsgi.py
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000
CORS_ORIGINS=*

# ── Ollama (only needed when LLM_BACKEND=ollama) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
